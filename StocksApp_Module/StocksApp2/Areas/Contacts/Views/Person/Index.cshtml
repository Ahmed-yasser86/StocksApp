@using ServiceContracts.DTOs
@using ServiceContracts.DTOs.Enums
@model IEnumerable<PersonRespones>

@{
    ViewData["Title"] = "Contacts List";
}

@* Everything is inside this form to ensure state is maintained *@
<form asp-area ="Contacts" asp-controller="Person" asp-action="Index" method="get">

    <div class="row m-1">
        <div class="col-8">
            <h2>People Directory</h2>
        </div>
    </div>

    <div class="search-box mb-3 p-3 bg-light border rounded">
        <div class="row g-3">
            <div class="col-md-3">
                <select name="searchBy" class="form-select">
                    @if (ViewBag.SearchFields != null)
                    {
                        foreach (var field in (Dictionary<string, string>)ViewBag.SearchFields)
                        {
                            bool isSelected = field.Key == (string)ViewBag.CurrentSearchBy;
                            <!option value="@field.Key" @(isSelected ? "selected" : "")>
                            @field.Value
                            </!option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-6">
                <input type="text" name="searchString" class="form-control"
                       placeholder="Search..." value="@ViewBag.CurrentSearchString" />
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </div>
    </div>

    <table class="table table-striped table-hover mt-4">
        <thead class="thead-dark">
            <tr>
                <th>
                    @if (ViewBag.CurrentSortedBy == nameof(PersonRespones.Name) && ViewBag.CurrentSortOption == sortedListOp.Ascending.ToString())
                    {
                        <a href="/Person/Index?searchBy=@ViewBag.CurrentSearchBy&searchString=@ViewBag.CurrentSearchString&SortedBy=@nameof(PersonRespones.Name)&SortOption=@sortedListOp.Descending.ToString()">
                            Name ↓ 
                        </a>
                    }
                    else if (ViewBag.CurrentSortedBy == nameof(PersonRespones.Name) && ViewBag.CurrentSortOption == sortedListOp.Descending.ToString())
                    {
                        <a href="/Person/Index?searchBy=@ViewBag.CurrentSearchBy&searchString=@ViewBag.CurrentSearchString&SortedBy=@nameof(PersonRespones.Name)&SortOption=@sortedListOp.Ascending.ToString()">
                            Name ↑ 
                        </a>
                    }
                    else
                    {
                        <a href="/Person/Index?searchBy=@ViewBag.CurrentSearchBy&searchString=@ViewBag.CurrentSearchString&SortedBy=@nameof(PersonRespones.Name)&SortOption=@sortedListOp.Ascending.ToString()">
                            Name
                        </a>
                    }
                </th>

                <th>Email</th>
                <th>Phone</th>
                <th>Gender</th>
                <th>Date of Birth</th>
                <th>Address</th>
                <th>Newsletter</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var person in Model)
            {
                <tr>
                    <td><strong>@person.Name</strong></td>
                    <td>@person.email</td>
                    <td>@person.phone</td>
                    <td>@person.Gender</td>
                    <td>
                        @(person.DateOfBirth.HasValue
                                            ? person.DateOfBirth.Value.ToString("MMM dd, yyyy")
                                            : "N/A")
                </td>
                <td>@person.Address</td>
                <td class="text-center">
                    <input type="checkbox" @(person.NewsLetter == true ? "checked" : "") disabled />
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@person.PersonId" class="btn btn-sm btn-outline-primary">Edit</a>
                </td>
            </tr>
                        }
        </tbody>
    </table>
</form>